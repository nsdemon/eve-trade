# Copy to .env and fill in. Alerts run when ALERT_EMAIL or ALERT_PHONE is set.
# On Vercel: set these in Project → Settings → Environment Variables. Add CRON_SECRET for cron auth.

# Where to send alerts
ALERT_EMAIL=you@example.com
ALERT_PHONE=+15551234567

# Email (e.g. Gmail). For Gmail use an App Password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# SMS via Twilio (https://www.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+15559876543
